# Copy to .env.docker (gitignored) before `docker compose up`
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-flash-latest
GEMINI_TIMEOUT_MS=30000

# Baked into the UI image at build time.
# Leave empty so the browser calls the same HTTPS origin; nginx proxies to the API.
VITE_API_BASE_URL=

# Baked into the UI image — must match backend VAPID_PUBLIC_KEY
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# Passed into the API container at runtime
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:admin@example.com
